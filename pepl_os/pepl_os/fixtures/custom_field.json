[
 {
  "name": "Item-custom_drawing_no",
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "custom_drawing_no",
  "label": "Drawing Number",
  "fieldtype": "Data",
  "insert_after": "item_name",
  "module": "PEPL OS"
 },
 {
  "name": "Item-custom_drawing_rev",
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "custom_drawing_rev",
  "label": "Current Drawing Revision",
  "fieldtype": "Data",
  "insert_after": "custom_drawing_no",
  "read_only": 1,
  "description": "Auto-fetched from active PEPL Item Drawing or PEPL Product Drawing",
  "module": "PEPL OS"
 },
 {
  "name": "Item-custom_pl_no",
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "custom_pl_no",
  "label": "PL Number (Railways)",
  "fieldtype": "Data",
  "insert_after": "custom_drawing_rev",
  "module": "PEPL OS"
 },
 {
  "name": "Item-custom_sector",
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "custom_sector",
  "label": "Default Sector",
  "fieldtype": "Select",
  "options": "\nRailways\nDefence\nPrivate\nOthers",
  "insert_after": "custom_pl_no",
  "module": "PEPL OS"
 },
 {
  "name": "Item-custom_is_product",
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "custom_is_product",
  "label": "Is a Product (Sold to Customer)",
  "fieldtype": "Check",
  "insert_after": "custom_sector",
  "default": "0",
  "description": "Tick if this item is something PEPL sells to customers (vs. a sub-component)",
  "module": "PEPL OS"
 },
 {
  "name": "Item-custom_product_type",
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "custom_product_type",
  "label": "Product Type",
  "fieldtype": "Select",
  "options": "\nSingle Component\nAssembly\nSub-Assembly",
  "insert_after": "custom_is_product",
  "depends_on": "eval:doc.custom_is_product==1",
  "module": "PEPL OS"
 },
 {
  "name": "Request for Quotation Item-target_vendors",
  "doctype": "Custom Field",
  "dt": "Request for Quotation Item",
  "fieldname": "target_vendors",
  "label": "Target Vendors",
  "fieldtype": "Table MultiSelect",
  "options": "PEPL RFQ Item Target Vendor",
  "insert_after": "description",
  "module": "PEPL OS"
 },
 {
  "doctype": "Custom Field",
  "name": "Purchase Order-linked_quotation_comparison",
  "dt": "Purchase Order",
  "fieldname": "linked_quotation_comparison",
  "label": "Linked Quotation Comparison",
  "fieldtype": "Link",
  "options": "PEPL Quotation Comparison",
  "insert_after": "supplier",
  "read_only": 1,
  "no_copy": 1,
  "module": "PEPL OS",
  "owner": "Administrator",
  "modified_by": "Administrator"
 }
]
